# Copy to .env for local runs; in GitHub set these as repo Secrets (Settings → Secrets and variables → Actions).
# EVERYTHING is optional — the pipeline degrades gracefully without any of these.

# --- LLM (pick one; Anthropic preferred if both set) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6
# OPENAI_MODEL=gpt-4o

# --- YouTube publishing (OAuth refresh-token flow) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Notifications ---
DISCORD_WEBHOOK=

# --- Self-hosted GPU (Wav2Lip), only on your local runner ---
# Path to a Wav2Lip checkout containing checkpoints/wav2lip_gan.pth
WAV2LIP_DIR=
