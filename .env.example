# Copy to .env for local runs; in GitHub set these as repo Secrets (Settings → Secrets and variables → Actions).
# EVERYTHING is optional — the pipeline degrades gracefully without any of these.

# --- LLM = Claude (Anthropic). Set this for real cloud-generated scripts ---
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-opus-4-8   # default (same model Claude Code uses); set claude-sonnet-4-6 for cheaper runs
# (OpenAI also supported as a fallback if you prefer)
OPENAI_API_KEY=

# --- YouTube publishing (OAuth refresh-token flow) ---
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- TikTok publishing (Content Posting API) ---
TIKTOK_ACCESS_TOKEN=
# TIKTOK_PRIVACY=SELF_ONLY      # use PUBLIC_TO_EVERYONE to go fully public

# --- Bilibili publishing (via biliup CLI + login cookies) ---
BILIBILI_COOKIES=               # path to biliup cookies.json (from `biliup login`)
# BILIBILI_TID=21               # partition id (21 = 日常)

# --- Notifications ---
DISCORD_WEBHOOK=
